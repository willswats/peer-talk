		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@types/node": "^22.19.0",
		"@vitest/browser": "^3.2.4",
		"eslint": "^9.39.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.13.0",
		"globals": "^16.5.0",
		"playwright": "^1.56.1",
		"prettier": "^3.6.2",
		"prettier-plugin-svelte": "^3.4.0",
		"svelte": "^5.43.2",
		"svelte-check": "^4.3.3",
